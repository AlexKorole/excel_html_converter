PORT=8000
HOST=localhost

# Куда складывать загруженные xlsx и сгенерированные отчёты. По умолчанию
# (если не задано) - папка "reports" там, откуда запущена команда (не
# внутри самого пакета - важно при установке через npm, node_modules
# может быть пересоздан командой npm install в любой момент).
# Раскомментируй и укажи свой путь, если хочешь другое расположение:
# REPORTS_DIR=/var/data/excel-html-converter/reports

# Лимиты по умолчанию для сайта (не для CLI-режима конвертеров - там
# свои встроенные фолбэки в коде). Пусто/строка отсутствует = используется
# фолбэк из кода конвертера.
TABLE_DEFAULT_ROW_LIMIT=5000
PIVOT_DEFAULT_ROW_LIMIT=500000
