PORT=8000
HOST=localhost

# Where to store uploaded xlsx files and generated reports. Defaults
# (if not set) to a "reports" folder next to wherever the command is
# run from - not inside the package itself (matters when installed via
# npm, since node_modules can be recreated by npm install at any time).
# Uncomment and set your own path if you want a different location:
# REPORTS_DIR=/var/data/excel-html-converter/reports

# Default limits for the website (not for the converters' CLI mode -
# that has its own built-in fallbacks in code). Empty/missing = the
# converter's own built-in fallback is used.
TABLE_DEFAULT_ROW_LIMIT=5000
PIVOT_DEFAULT_ROW_LIMIT=500000
